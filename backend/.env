# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (預設，輕量開發用)
DATABASE_URL=sqlite+aiosqlite:///./kgi.db
# PostgreSQL (正式環境備用)
# DATABASE_URL=postgresql+asyncpg://kgi:kgi_secret@localhost:5432/kgi_db

# ── Redis / Celery ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── LLM Provider ──────────────────────────────────────────────────────────────
# 切換 LLM 只需修改此欄位 (azure_openai | openai)
LLM_PROVIDER=azure_openai

# Azure OpenAI
AOAI_ENDPOINT=aoai_endpoint
AOAI_API_KEY=aoai_api_key
AOAI_DEPLOYMENT=gpt-4o
AOAI_API_VERSION=2024-12-01-preview

# OpenAI (備用)
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
UPLOAD_MAX_SIZE_MB=20
