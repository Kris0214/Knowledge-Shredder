# ── Database ──────────────────────────────────────────────────────────────────
# SQLite
DATABASE_URL=sqlite+aiosqlite:///./kgi.db

# ── LLM Provider ──────────────────────────────────────────────────────────────
# LLM接口 (azure_openai | openai | gemini)
LLM_PROVIDER=azure_openai

# Azure OpenAI
AOAI_ENDPOINT=your_azure_endpoint
AOAI_API_KEY=your_azure_api_key
AOAI_DEPLOYMENT=gpt-4o
AOAI_API_VERSION=your_azure_api_version

# OpenAI
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4o

# Google Gemini
GEMINI_API_KEY=gemini_key
GEMINI_MODEL=gemini-2.0-flash

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
UPLOAD_MAX_SIZE_MB=20
